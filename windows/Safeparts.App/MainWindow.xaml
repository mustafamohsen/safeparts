<Window x:Class="Safeparts.WinUI.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:model="using:Safeparts.AppModel">
 <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
  <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="12,0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
   <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
   <Image Source="Assets/safeparts-logo.png" Width="24" Height="24" VerticalAlignment="Center" AutomationProperties.Name="Safeparts logo"/>
   <TextBlock Grid.Column="1" Text="Safeparts" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="8,0" VerticalAlignment="Center"/>
   <TextBlock Grid.Column="3" Text="Local only" VerticalAlignment="Center" Margin="12,0" AutomationProperties.Name="Cryptographic operations run locally"/>
  </Grid>
  <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Padding="16,10">
   <RadioButton x:Name="SplitTaskButton" Content="Split" GroupName="Task" IsChecked="True" Checked="TaskChanged" AutomationProperties.AutomationId="TaskSplit"/>
   <RadioButton x:Name="RecoverTaskButton" Content="Recover" GroupName="Task" Checked="TaskChanged" AutomationProperties.AutomationId="TaskRecover"/>
  </StackPanel>
  <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
   <Grid MaxWidth="920" HorizontalAlignment="Center" Padding="24,8,24,32">
    <StackPanel x:Name="SplitPanel" Spacing="16">
     <TextBlock Text="Split a Secret" Style="{StaticResource TitleTextBlockStyle}"/>
     <TextBlock Text="Create Recovery shares without sending data anywhere." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
     <StackPanel x:Name="TextSecretPanel" Spacing="8">
      <TextBlock Text="Secret" Style="{StaticResource BodyStrongTextBlockStyle}"/>
      <TextBox x:Name="SecretTextBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" TextChanged="SecretTextChanged" AutomationProperties.Name="Secret text" AutomationProperties.AutomationId="SecretText"/>
      <StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Paste" Click="PasteSecretClicked"/><Button Content="Import file…" Click="ImportSecretClicked"/></StackPanel>
     </StackPanel>
     <StackPanel x:Name="ImportedSecretPanel" Visibility="Collapsed" Spacing="8"><TextBlock x:Name="ImportedSecretText"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Replace file…" Click="ImportSecretClicked"/><Button Content="Use text instead" Click="UseTextClicked"/></StackPanel></StackPanel>
     <Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
      <StackPanel><TextBlock Text="Threshold"/><NumberBox x:Name="ThresholdBox" Minimum="1" Maximum="255" SpinButtonPlacementMode="Inline" Value="2" ValueChanged="ThresholdChanged" AutomationProperties.Name="Minimum Recovery shares"/></StackPanel>
      <StackPanel Grid.Column="1"><TextBlock Text="Share count"/><NumberBox x:Name="ShareCountBox" Minimum="1" Maximum="255" SpinButtonPlacementMode="Inline" Value="3" ValueChanged="ShareCountChanged" AutomationProperties.Name="Total Recovery shares"/></StackPanel>
     </Grid>
     <StackPanel><TextBlock Text="Share encoding"/><ComboBox x:Name="SplitEncodingBox" SelectionChanged="SplitEncodingChanged" AutomationProperties.Name="Share encoding" AutomationProperties.AutomationId="SplitEncoding"/></StackPanel>
     <StackPanel><TextBlock Text="Passphrase (optional)"/><PasswordBox x:Name="SplitPassphraseBox" PasswordChanged="SplitPassphraseChanged" AutomationProperties.Name="Split passphrase"/></StackPanel>
     <Button x:Name="SplitButton" Content="Split" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" Click="SplitClicked" AutomationProperties.AutomationId="SplitAction"/>
     <InfoBar x:Name="SplitStatus" IsOpen="False"/>
     <ItemsControl x:Name="ShareList"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12" Margin="0,4" CornerRadius="6"><StackPanel Spacing="8"><TextBlock Text="{Binding Index}" FontWeight="SemiBold" AutomationProperties.Name="Recovery share index"/><TextBox Text="{Binding Text}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" AutomationProperties.Name="Recovery share text"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Copy" Tag="{Binding}" Click="CopyShareClicked"/><Button Content="Save…" Tag="{Binding}" Click="SaveShareClicked"/></StackPanel></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
     <StackPanel x:Name="ExportPanel" Visibility="Collapsed" Spacing="8"><TextBox x:Name="ExportPrefixBox" Header="Filename prefix (optional)" TextChanged="ExportPrefixChanged"/><Button Content="Export all…" HorizontalAlignment="Left" Click="ExportAllClicked"/></StackPanel>
    </StackPanel>
    <StackPanel x:Name="RecoverPanel" Visibility="Collapsed" Spacing="16">
     <TextBlock Text="Recover a Secret" Style="{StaticResource TitleTextBlockStyle}"/>
     <TextBlock Text="Enter enough Recovery shares from the same set." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
     <StackPanel><TextBlock Text="Share encoding"/><ComboBox x:Name="RecoveryEncodingBox" SelectionChanged="RecoveryEncodingChanged" AutomationProperties.Name="Recovery Share encoding" AutomationProperties.AutomationId="RecoveryEncoding"/></StackPanel>
     <PasswordBox x:Name="RecoveryPassphraseBox" Header="Passphrase" IsEnabled="False" PasswordChanged="RecoveryPassphraseChanged"/>
     <TextBlock x:Name="RecoveryReadinessText" Text="Waiting for Recovery shares" AutomationProperties.LiveSetting="Polite" AutomationProperties.AutomationId="RecoveryReadiness"/>
     <ItemsControl x:Name="RecoveryFieldList"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12" Margin="0,4" CornerRadius="6"><StackPanel Spacing="8"><TextBox Text="{Binding Text, Mode=TwoWay}" Tag="{Binding Id}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" TextChanged="RecoveryFieldTextChanged" AutomationProperties.Name="Recovery share"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Paste" Tag="{Binding Id}" Click="PasteRecoveryFieldClicked"/><Button Content="Clear" Tag="{Binding Id}" Click="ClearRecoveryFieldClicked"/><Button Content="Remove" Tag="{Binding Id}" Click="RemoveRecoveryFieldClicked"/></StackPanel></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
     <StackPanel Orientation="Horizontal" Spacing="8"><Button Content="Paste shares" Click="PasteSharesClicked"/><Button Content="Import files…" Click="ImportSharesClicked"/><Button Content="Add share" Click="AddRecoveryFieldClicked"/></StackPanel>
     <Button x:Name="RecoverButton" Content="Recover Secret" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" Click="RecoverClicked" AutomationProperties.AutomationId="RecoverAction"/>
     <InfoBar x:Name="RecoveryStatus" IsOpen="False"/>
     <Border x:Name="RecoveredPanel" Visibility="Collapsed" Background="{ThemeResource AccentFillColorSecondaryBrush}" Padding="12" CornerRadius="6"><StackPanel Spacing="8"><TextBlock Text="Recovered Secret" FontWeight="SemiBold"/><TextBox x:Name="RecoveredTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" AutomationProperties.Name="Recovered Secret text" AutomationProperties.AutomationId="RecoveredText"/><TextBlock x:Name="RecoveredBytesText"/><StackPanel Orientation="Horizontal" Spacing="8"><Button x:Name="CopyRecoveredButton" Content="Copy" Click="CopyRecoveredClicked"/><Button Content="Save…" Click="SaveRecoveredClicked"/></StackPanel></StackPanel></Border>
    </StackPanel>
   </Grid>
  </ScrollViewer>
 </Grid>
</Window>
